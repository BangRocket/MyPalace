# Palace Memory Service — environment variables
# Copy to .env and fill in.

# PostgreSQL
PALACE_DATABASE_URL=postgresql+asyncpg://palace:palace@localhost:5442/palace

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=palace_memories

# Embeddings
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
HF_TOKEN=
OPENAI_API_KEY=

# LLM (any OpenAI-compatible chat completion endpoint)
LLM_PROVIDER=openrouter
LLM_API_KEY=
LLM_MODEL=openai/gpt-4o-mini

# Logging
LOG_LEVEL=INFO
