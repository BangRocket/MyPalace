# --------------------------------------------------------------------
# MyPalace env template
#
# For LOCAL development, the defaults work as-is — copy to `.env` and
# you're done. For PRODUCTION (docker-compose.prod.yml), the two
# REQUIRED vars at the top must be set or the stack refuses to start.
# See docs/deployment.md for the full production setup.
# --------------------------------------------------------------------

# REQUIRED in production — bootstrap admin key (pk_live_<32 alphanumeric>)
#   echo "pk_live_$(LC_ALL=C tr -dc 'A-Za-z0-9' </dev/urandom | head -c 32)"
# MyPalace mints a cross-tenant admin key with this value on first boot
# and never logs the value again — save it somewhere safe.
PALACE_BOOTSTRAP_ADMIN_KEY=

# REQUIRED in production (docker-compose.prod.yml). For local dev,
# the docker-compose.yml uses the literal "palace" password.
POSTGRES_PASSWORD=

# --------------------------------------------------------------------
# Local development defaults (docker-compose.yml)
# --------------------------------------------------------------------

PALACE_DATABASE_URL=postgresql+asyncpg://palace:palace@localhost:5442/palace
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=palace_memories

EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
HF_TOKEN=
OPENAI_API_KEY=

LLM_PROVIDER=openrouter
LLM_API_KEY=
LLM_MODEL=openai/gpt-4o-mini

LOG_LEVEL=INFO
PALACE_LOG_FORMAT=pretty

# --------------------------------------------------------------------
# Optional production overrides (uncomment when deploying)
# --------------------------------------------------------------------

# Image tag for docker-compose.prod.yml
# MYPALACE_VERSION=0.7.1

# HTTP port to expose on the host
# MYPALACE_HTTP_PORT=8000

# Postgres user + db (defaults `mypalace`/`mypalace` for the prod compose)
# POSTGRES_USER=mypalace
# POSTGRES_DB=mypalace

# Rate limits (defaults: 120/min general, 60/min search)
# PALACE_RATE_LIMIT_DEFAULT=120
# PALACE_RATE_LIMIT_SEARCH=60

# Cache TTLs in seconds
# PALACE_CACHE_TTL_SEARCH=60
# PALACE_CACHE_TTL_GET=300

# DB query observability
# PALACE_DB_SLOW_QUERY_MS=200

# OpenTelemetry traces (requires `pip install "mypalace[otel]"`)
# PALACE_OTLP_ENDPOINT=http://otel-collector:4317
# PALACE_OTLP_SERVICE_NAME=mypalace

# Worker tuning
# PALACE_WORKER_POLL_INTERVAL=1.0
# PALACE_WORKER_LEASE_SECONDS=60
# PALACE_WORKER_MAX_ATTEMPTS=3
